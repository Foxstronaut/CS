#!/bin/bash
set -e

# fetch latest jjava release URL dynamically
JJAVA_URL=$(curl -s https://api.github.com/repos/dflib/jjava/releases/latest \
  | grep "browser_download_url.*\.zip" \
  | cut -d '"' -f 4)

echo "Downloading: $JJAVA_URL"
wget -q "$JJAVA_URL" -O jjava.zip
unzip jjava.zip
cd jjava-*/
python install.py --sys-prefix